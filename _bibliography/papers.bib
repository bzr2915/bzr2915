@inproceedings{tSS-BO,
  title={tSS-BO: Scalable Bayesian Optimization for Analog Circuit Sizing via Truncated Subspace Sampling},
  author={Gu, Tianchen and Wang, Jiaqi and Bi*, Zhaori and Yan, Changhao and Yang, Fan and Qin, Yajie and Cui, Tao and Zeng, Xuan},
  booktitle={2024 Design, Automation and Test in Europe Conference (DATE 24)},
  pages={1},
  year={2024},
  organization={IEEE},
  abbr={DATE},
  label={AI for EDA},
  abstract={Bayesian optimization (BO) has emerged as a powerful tool for analog circuit sizing, yet its scalability to high-dimensional design spaces remains a critical challenge. This paper proposes tSS-BO, a novel scalable Bayesian optimization method with truncated subspace sampling for large-scale analog circuit sizing. The method addresses the curse of dimensionality by performing optimization in truncated subspaces that capture the most important design variable interactions, thereby reducing the effective dimensionality of the problem while preserving optimization quality. The truncated subspace is adaptively constructed based on observed data to focus the search on the most influential dimensions. Experimental results on both synthetic benchmarks and real-world analog circuits demonstrate that tSS-BO significantly outperforms existing high-dimensional Bayesian optimization methods in terms of optimization efficiency and solution quality.}
}
@inproceedings{CRC,
  title={Circuits Physics Constrained Predictor of Static IR Drop with Limited Data},
  author={Meng, Yuan and Lyu, Ruiyu and Bi*, Zhaori and Yan, Changhao and Yang, Fan and Hu, Wenchuang and Zhou, Dian and Zeng, Xuan},
  booktitle={2024 Design, Automation and Test in Europe Conference (DATE 24)},
  pages={1},
  year={2024},
  organization={IEEE},
  abbr={DATE},
  label={AI for EDA},
  abstract={Accurate prediction of static IR drop in power delivery networks (PDN) is crucial for ensuring reliable chip operation. However, existing learning-based methods require large amounts of training data, which is expensive to obtain through detailed simulation. This paper proposes a circuits physics constrained predictor that achieves highly accurate IR drop prediction with limited data. A pyramid scene parsing network with skip-connection architecture is employed to effectively utilize physical information that characterizes IR drop distribution, including current source locations, via locations, and asymmetric topological connections. The skip-connection architecture preserves the positional information of current sources, which often correlates with large IR drop, facilitating the identification of hotspots. Via locations are incorporated to effectively describe the topological connection distance between voltage sources and different nodes in the multi-layer PDN. Experimental results demonstrate that the proposed method achieves high prediction accuracy for PDN of varying scales even with a limited dataset.}
}

@inproceedings{zhao2024multiobj,
  title={Synchronous Batch Constrained Multi-Objective Bayesian Optimization for Analog Circuit Sizing},
  author={Zhao, Xuyang and Bi*, Zhaori and Yan, Changhao and Yang, Fan and Lu, Ye and Zhou, Dian and Zeng, Xuan},
  booktitle={2024 29th Asia and South Pacific Design Automation Conference (ASP-DAC 24)},
  pages={1},
  year={2024},
  organization={IEEE},
  abbr={ASP-DAC},
  label={AI for EDA},
  abstract={For analog circuit sizing, constrained multi-objective optimization is an important and practical problem. With the popularity of multi-core machines and cloud computing, parallel batch computing can significantly improve the efficiency of optimization algorithms. This paper proposes an asynchronous batch constrained multi-objective Bayesian optimization algorithm (ABCMOBO) for analog circuit sizing. The algorithm adopts a dynamic reference point selection on the expected hypervolume improvement acquisition function for constraint handling. To save the time of waiting for all simulations in the same batch to complete, ABCMOBO asynchronously evaluates the next candidate point if there is an idle worker. Experimental results quantitatively demonstrate that the proposed algorithm can reach 3.49 to 8.18x speed-up with comparable optimization results compared to the state-of-the-art asynchronous and synchronous batch multi-objective optimization methods.}
}
@inproceedings{lv2024multiobj,
  title={A Study on Exploring and Exploiting the High-dimensional Design Space for Analog Circuit Design Automation},
  author={Lyu, Ruiyu and Meng, Yuan and Zhao, Aidong and Bi*, Zhaori and Zhu, Keren and Yang, Fan and Yan, Changhao and Zhou, Dian and Zeng, Xuan},
  booktitle={2024 29th Asia and South Pacific Design Automation Conference (ASP-DAC 24)},
  pages={1},
  year={2024},
  organization={IEEE},
  abbr={ASP-DAC},
  label={AI for EDA},
  abstract={The escalated intricacy of analog circuits, compounded by the high-dimensional nature of the design space, introduces significant complexities in optimizing circuit performance. Since circuit evaluation through simulation is resource-intensive and time-consuming, the goal is to obtain a feasible design with a decent Figure of Merit (FOM) value within a limited simulation budget. This paper conducts an in-depth review and analysis of cutting-edge exploration and exploitation techniques developed to address the intricacies encountered in analog circuit design automation. We systematically examine methods for navigating the high-dimensional design space, including subspace decomposition, dimensionality reduction, and local search strategies, and discuss their effectiveness in balancing exploration of unknown regions with exploitation of promising areas for efficient analog circuit sizing.}
}
@inproceedings{zhao2022novel,
  title={A Novel and Efficient Bayesian Optimization Approach for Analog Designs with Multi-Testbench},
  author={Zhao, Jingyao and Yan, Changhao and Bi, Zhaori and Yang, Fan and Zeng, Xuan and Zhou, Dian},
  booktitle={2022 27th Asia and South Pacific Design Automation Conference (ASP-DAC 22)},
  pages={86--91},
  year={2022},
  organization={IEEE},
  abbr={ASP-DAC},
  label={AI for EDA},
  abstract={Analog circuits are characterized by various circuit performances obtained from multiple testbenches which need to be simulated independently. This paper proposes a novel and efficient Bayesian optimization approach for analog designs with multi-testbench. Predictive Entropy Search with Constraints (PESC) is applied for selecting the suitable testbench to simulate, and time-weighted PESC (wPESC) is also proposed considering different analysis time. Furthermore, the Feasibility Expected Improvement (FEI) acquisition function for constraints and solving a multi-modal optimal problem of FEI are proposed to improve the efficiency of exploring feasible regions. Experimental results on real-world analog circuits demonstrate that the proposed approach can gain 2.7 to 3.8x speedup compared with the state-of-the-art method, and achieve better optimization results.}
}
@inproceedings{fu2022batch,
  title={A Batch Bayesian Optimization Approach For Analog Circuit Synthesis Based On Multi-Points Selection Criterion},
  author={Fu, Xu and Yan, Changhao and Bi, Zhaori and Yang, Fan and Zhou, Dian and Zeng, Xuan},
  booktitle={2022 IEEE International Symposium on Circuits and Systems (ISCAS 22)},
  pages={2886--2890},
  year={2022},
  organization={IEEE},
  abbr={ISCAS},
  label={AI for EDA},
  abstract={This paper proposes an efficient batch Bayesian optimization algorithm for analog circuit synthesis based on the multi-points selection criterion. Simplex evolution operator and Niching Migratory Multi-Swarm Optimizer (NMMSO) are used to generate candidates. The multi-point selection criterion is adopted to select multiple points from the candidates for parallel evaluation, which can make full use of the computing resources. The experimental results demonstrate that this method can reduce the simulation time effectively while achieving better optimization results. Compared with the Multi-objective Acquisition function Ensemble (MACE) and the weighted expected improvement based Bayesian optimization (WEIBO), the proposed approach can accelerate the optimization process by up to 3x and 27x respectively.}
}
@inproceedings{iseda1,
  title={HD-MCTS: An Analog Circuit Optimization Algorithm Based on High-dimensional Monte Carlo Tree Search},
  author={Yiyang, Zhao and Li, Lemeng and Lyv, Ruiyu and Bi*, Zhaori and Yan, Changhao and  Zeng, Xuan},
  booktitle={2022 IEEE International Symposium of EDA (ISEDA 24), best paper},
  year={2024},
  organization={IEEE},
  abbr={ISEDA},
  label={AI for EDA},
  abstract={With the development of semiconductor technology, the design of analog circuits still relies heavily on manual effort, creating an urgent need for automated design tools. This paper proposes HD-MCTS, an analog circuit optimization algorithm based on high-dimensional Monte Carlo tree search. The method combines the advantages of Bayesian optimization and dynamic Monte Carlo tree search to obtain the feasible solution space through adaptive clustering, thereby narrowing the search range of the Bayesian optimization algorithm and improving optimization efficiency. For the Ackley test function, low-noise transconductance amplifier and bandgap voltage reference experiments, compared with Trust Region Bayesian Optimization (TuRBO), the optimization outcomes are enhanced by 20.4 percent to 46.5 percent, leading to a speedup of 0.95 to 2.62 times.}
}
@inproceedings{iseda2,
  title={High-Dimensional Analog Circuit Sizing via Bayesian Optimization in the Variational Autoencoder Enhanced Latent Space },
  author={Li, Wangzhen and Bi*, Zhaori and Zeng, Xuan},
  booktitle={2022 IEEE International Symposium of EDA (ISEDA 24)},
  year={2024},
  organization={IEEE},
  abbr={ISEDA},
  label={AI for EDA},
  abstract={High-dimensional analog circuit sizing is a challenging optimization problem due to the curse of dimensionality and expensive circuit simulations. This paper proposes a method for high-dimensional analog circuit sizing via Bayesian optimization in a variational autoencoder (VAE) enhanced latent space. The VAE is trained on circuit design data to learn a compact, continuous latent representation that captures meaningful relationships between design parameters. Bayesian optimization is then performed in this lower-dimensional latent space, enabling more efficient exploration of the design space. The approach effectively reduces the dimensionality of the optimization problem while preserving the essential structure of the design space, leading to improved optimization efficiency and solution quality for large-scale analog circuit sizing.}
}
@inproceedings{iseda3,
  title={Automated Design of Analog Circuits Based on Parallel Trust Region Bayesian Optimization},
  author={Dong, Peng and Lyu, Ruiyu and Wang, Chunxi and Chen, Jiale and Jiang, Linfeng and Lan, Cunqing and Bi*, Zhaori and Yan, Changhao},
  booktitle={2022 IEEE International Symposium of EDA (ISEDA 24)},
  year={2024},
  organization={IEEE},
  abbr={ISEDA},
  label={AI for EDA},
  abstract={Automated analog circuit design requires efficient optimization methods that can handle the complex, multi-dimensional parameter spaces of modern circuits. This paper proposes an automated design approach for analog circuits based on parallel trust region Bayesian optimization. The algorithm operates in parallel on different trust regions, utilizing a Multi-Armed Bandit algorithm for intelligent sampling to accelerate parameter optimization. By maintaining multiple trust regions simultaneously, the method effectively balances local exploitation within promising regions and global exploration of the design space. Circuit experimental results demonstrate the advantages of this algorithm in achieving faster convergence and better optimization outcomes compared to existing approaches.}
}
@inproceedings{iseda4,
  title={Topology Optimization of Operational Amplifiers Using A Performance-aware Representation},
  author={Shen, Jinyi and Yang, Fan and Shang, Li and Yan, Changhao and Bi, Zhaori and Zhou, Dian and Zeng, Xuan},
  booktitle={2022 IEEE International Symposium of EDA (ISEDA 24)},
  year={2024},
  organization={IEEE},
  abbr={ISEDA},
  label={AI for EDA},
  abstract={Automated topology synthesis of operational amplifiers is a fundamental challenge in analog circuit design automation. This paper proposes a performance-aware representation for topology optimization of operational amplifiers that encodes circuit topologies in a way that captures their performance characteristics. The representation enables efficient search over the discrete topology space by embedding performance-relevant structural information, allowing optimization algorithms to effectively navigate the vast space of possible amplifier configurations. Experimental results demonstrate that the proposed performance-aware representation leads to more efficient topology optimization and the discovery of high-quality operational amplifier designs.}
}
@inproceedings{iseda5,
  title={On  Accelerating  Domain-Specific  MC-TS  with  Knowledge  Retention  and  Efficient  Parallelization  for  Logic Optimization},
  author={Lan, Cunqing and Wang, Xinyao and Jiang, Zijian and Pan, Hongyang and Zhu, Keren and Bi, Zhaori and Yan, Changhao and Zeng, Xuan},
  booktitle={2022 IEEE International Symposium of EDA (ISEDA 24)},
  year={2024},
  organization={IEEE},
  abbr={ISEDA},
  label={AI for EDA},
  abstract={Logic synthesis optimization is a critical step in the electronic design automation flow, where the quality of the synthesis recipe significantly impacts the Quality-of-Result (QoR). This paper proposes a method for accelerating domain-specific Monte Carlo tree search (MC-TS) with knowledge retention and efficient parallelization for logic optimization. The approach incorporates a knowledge retention mechanism that preserves and reuses valuable search experiences across different optimization runs, avoiding redundant exploration. Furthermore, an efficient parallelization strategy is designed to enable concurrent evaluation of multiple synthesis recipes, significantly reducing the total optimization time. Experimental results demonstrate that the proposed method achieves superior QoR compared to existing approaches while substantially reducing the computational overhead.}
}
@inproceedings{li2015analog,
  title={Analog circuit performance bound estimation based on extreme value theory},
  author={Li, Minghua and Bi, Zhaori and Zhou, Dian and Zeng, Xuan},
  booktitle={2015 IEEE 58th International Midwest Symposium on Circuits and Systems (MWSCAS 15)},
  pages={1--4},
  year={2015},
  organization={IEEE},
  abbr={MWSCAS},
  label={AI for EDA},
  abstract={Performance bound estimation is an important task in analog circuit design, as it provides designers with critical information about the achievable performance limits under process variations. This paper proposes a novel performance bound estimation method for analog circuits based on extreme value theory. The method generates a generalized extreme value (GEV) distribution of performance parameters through sampling, enabling accurate estimation of the worst-case and best-case performance bounds without exhaustive Monte Carlo simulations. The approach provides a statistically rigorous framework for bounding circuit performance and offers significant computational savings compared to traditional methods.}
}

@inproceedings{bi2013mixed,
  title={Mixed-signal system verification by SystemC/SystemC-AMS and HSIM-VCS in near field communication tag design},
  author={Bi, Zhaori and Li, Wei and Zhou, Dian and Zeng, Xuan and Wang, Sheng-Guo},
  booktitle={2013 IEEE 10th International Conference on ASIC (ASCION 13)},
  pages={1--4},
  year={2013},
  organization={IEEE},
  abbr={ASCION},
  label={AI for EDA},
  abstract={This paper presents a verification methodology for mixed-signal systems by combining SystemC/SystemC-AMS and HSIM-VCS verification platforms. The methodology is applied to design a Near Field Communication (NFC) tag and verify its function under certain noise conditions. SystemC-AMS is used for high-level behavioral modeling of the analog and mixed-signal components, while HSIM-VCS provides transistor-level simulation accuracy for critical circuit blocks. The combined approach enables efficient system-level verification of the NFC tag design, balancing simulation speed and accuracy across different levels of abstraction.}
}


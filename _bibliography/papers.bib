@inproceedings{mario,
  title={MARIO: A Superadditive Multi-Algorithm Interworking Optimization Framework for Analog Circuit Sizing},
  author={Li, Wangzhen and Meng, Yuan and Lyu, Ruiyu and Yan, Changhao and Zhu, Keren and Bi, Zhaori and Zhou, Dian and Zeng, Xuan},
  booktitle={2025 62nd ACM/IEEE Design Automation Conference (DAC 25)},
  pages={1--7},
  year={2025},
  organization={IEEE},
  abbr={DAC},
  label={AI for EDA},
  selected={true},
  abstract={Numeric optimization methods are widely utilized to tackle complex analog circuit sizing problems, where the challenges include expensive simulations, non-linearity, and high parameter dimensionality. However, the diverse characteristics exhibited by different circuits result in varied optimization landscapes, making it difficult to identify a single algorithm that consistently outperforms others across all problems. This paper proposes MARIO, a multi-algorithm interworking optimization framework that achieves optimization superadditivity based on a pool of member algorithms and a powerful algorithm-interworking protocol. A computing resource reallocation method is proposed, which employs multi-task Gaussian process regression and portfolio optimization techniques, leading to flexible and prudent online adaption of member algorithms. Furthermore, a cooperative local refinement feature is introduced, allowing algorithms to share evaluation data and leverage each other's strengths for local search. Experimental results on both synthetic benchmarks and real-world analog circuits demonstrate that MARIO surpasses existing algorithm-combining tools and standard optimization methods.}
}

@inproceedings{lbyl,
  title={Look Before You Leap: A Self-Review Bayesian Optimization Method for Constrained High-Dimensional Design Space Exploration},
  author={Zhao, Xuyang and Zhao, Yiyang and Wu, Zheng and Gao, Tianning and Bi*, Zhaori and Yan, Changhao and Zhou, Dian and Zeng, Xuan},
  booktitle={2025 62nd ACM/IEEE Design Automation Conference (DAC 25)},
  pages={1--7},
  year={2025},
  organization={IEEE},
  abbr={DAC},
  label={AI for EDA},
  selected={false},
  abstract={High-dimensional constrained optimization poses significant challenges in analog circuit design automation, where expensive simulations and complex design spaces hinder efficient exploration. This paper proposes a self-review Bayesian optimization method that integrates a teacher-student paradigm within a local Bayesian optimization framework to reduce model errors and enhance exploration efficiency in constrained high-dimensional design spaces. The method employs deep ensembles for effective constraint handling, enabling reliable identification of feasible regions. Experimental results on both synthetic benchmarks and real-world analog circuits demonstrate that the proposed approach achieves superior performance compared to state-of-the-art methods for constrained high-dimensional design space exploration.}
}

@inproceedings{himoss,
  title={HiMOSS: A Novel High-Dimensional Multi-Objective Optimization Method via Adaptive Gradient-Based Subspace Sampling for Analog Circuit Sizing},
  author={Gu, Tianchen and Lyu, Ruiyu and Bi*, Zhaori and Yan, Changhao and Yang, Fan and Zhou, Dian and Cui, Tao and  Liu, Xin and Zhang, Zaikun and Zeng, Xuan},
  booktitle={2024 61th ACM/IEEE Design Automation Conference (DAC 24)},
  year={2024},
  organization={IEEE},
  abbr={DAC},
  label={AI for EDA},
  selected={false},
  abstract={This study presents a novel high-dimensional multi-objective optimization method via adaptive gradient-based subspace sampling for analog circuit sizing. To handle constrained multi-objective optimization, we exploit promising regions from a non-crowded Pareto front, with lightweight Bayesian optimization (BO) based on a novel approximate constrained expected hypervolume improvement. This lightweight BO is computational efficient with constant complexity concerning simulation numbers. To tackle high-dimensional challenges, we reduce the effective dimensionality around promising regions by sampling candidates in an adaptive subspace. The subspace is constructed with gradients and previous success steps with their significance decaying over iterations. The gradients are approximated by sparse regression without additional simulations. The experiments on synthetic benchmarks and analog circuits illustrate advantages of the proposed method over Bayesian and evolutionary baselines.}
}

@inproceedings{evdmarl,
  title={EVDMARL: Efficient Value Decomposition-based Multi-Agent Reinforcement Learning with Domain-Randomization for Complex Analog Circuit Design Migration},
  author={Sun, Handa and Bi*, Zhaori and Jiang, Wenning and Lu, Ye and Yan, Changhao and Yang, Fan and Hu, Wenchuang and Wang, Sheng-Guo and Zhou, Dian and Zeng, Xuan},
  booktitle={2024 61th ACM/IEEE Design Automation Conference (DAC 24)},
  year={2024},
  organization={IEEE},
  abbr={DAC},
  label={AI for EDA},
  selected={true},
  abstract={Automated analog circuit design migration significantly alleviates the burden on designers in circuit sizing under various operating conditions. Conventional methods model the migration problem as black-box optimization, requiring excessive iterations of costly simulations to converge. Reinforcement learning exhibits significant promise in transfer learning, as it enables the generation of circuits that fulfill specifications efficiently. This paper proposes EVDMARL, a novel value decomposition-based multi-agent reinforcement learning framework that models complex analog circuits and eliminates the need for manually defined specifications of sub-circuits for new operating conditions. Furthermore, domain randomization is incorporated to efficiently generate circuits that meet unforeseen scenarios with minimal simulations. Experimental results on real-world analog circuits demonstrate the effectiveness of the proposed framework for complex analog circuit design migration.}
}

@inproceedings{zhao2023cvts,
  title={cVTS: A Constrained Voronoi Tree Search Method for High Dimensional Analog Circuit Synthesis},
  author={Zhao, Aidong and Wang, Xianan and Lin, Zixiao and Bi*, Zhaori and Li, Xudong and Yan, Changhao and Yang, Fan and Shang, Li and Zhou, Dian and Zeng, Xuan},
  booktitle={2023 60th ACM/IEEE Design Automation Conference (DAC 23)},
  year={2023},
  organization={IEEE},
  abbr={DAC},
  label={AI for EDA},
  selected={true},
  abstract={A constrained Voronoi tree-based domain decomposition method for high-dimensional Bayesian optimization is proposed to solve large scale analog circuit synthesis problems, which can be formulated as high-dimensional heterogeneous black-box optimization. The hierarchical Voronoi tree progressively breaks down the design space into partitions with implicit performance boundaries such that promising regions are efficiently explored. Combined with a local Bayesian optimization strategy within each partition, the method effectively balances exploration and exploitation in high-dimensional spaces. Experimental results on both synthetic benchmarks and real-world analog circuits demonstrate that the proposed method significantly outperforms state-of-the-art methods in terms of optimization quality and convergence speed.}
}

@inproceedings{zhao2025seeing,
  title={BAGNet: A Boundary-Aware Graph Neural Network for SRAM Yield Analysis in Post-Layout Simulation},
  author={Sang, Haoyang and Yan, Changhao and Bi*, Zhaori and Zhu, Keren and Zeng, Xuan},
  booktitle={2025 IEEE/ACM International Conference On Computer Aided Design (ICCAD 25)},
  pages={1--9},
  year={2025},
  organization={IEEE},
  abbr={ICCAD},
  label={AI for EDA},
  selected={false},
  abstract={SRAM yield analysis in post-layout simulation is critical for ensuring reliable memory designs under process variations. This paper proposes BAGNet, a boundary-aware graph neural network that captures the complex relationships between layout parasitics and SRAM yield metrics. By incorporating boundary-aware attention mechanisms and graph-based representations of the SRAM post-layout structure, BAGNet effectively models the spatial dependencies and boundary effects that significantly impact yield. Experimental results demonstrate that BAGNet achieves highly accurate SRAM yield predictions in post-layout simulation, outperforming existing methods while providing valuable insights for yield-driven design optimization.}
}

@inproceedings{sang,
  title={Seeing Through Designs: Attention-Based Knowledge Transfer for Preference-Guided Microarchitecture Search},
  author={Zhao, Yiyang and Zhao, Xuyang and Bi*, Zhaori and Zhu, Ming and Zhan, Qiwei and Zhu, Keren and Yang, Fan and Yan, Changhao and Zhou, Dian and Zeng, Xuan},
  booktitle={2025 IEEE/ACM International Conference On Computer Aided Design (ICCAD 25)},
  pages={1--9},
  year={2025},
  organization={IEEE},
  abbr={ICCAD},
  label={AI for EDA},
  selected={false},
  abstract={Modern processor microarchitectures face increasing complexity with larger search spaces and lengthy design-to-silicon validation flows. While reusing design knowledge across architectures offers efficiency gains, the common practice remains specific-architecture search due to discrepancies in power, performance, and area metrics. This paper proposes an attention-based microarchitecture search framework for effective cross-architecture knowledge transfer. A cross-attention network is designed to capture interdependencies between microarchitectural topology and design tool configurations, enabling knowledge adaptation across architectures with minimal fine-tuning. Complemented by an uncertainty-guided optimization strategy, the framework efficiently navigates the design space based on specific user preferences. Experimental results demonstrate that the proposed method achieves significant speedup in microarchitecture design space exploration while maintaining high-quality design outcomes.}
}

@inproceedings{ajoint,
  title={Revisiting sensitivity-based analog sizing with derivative-aware Bayesian optimization and error-suppressed adjoint analysis},
  author={Lyu, Ruiyu and Zhao, Aidong and Meng, Yuan and Zhu, Keren and Bi*, Zhaori and Yan, Changhao and Yang, Fan and Zhou, Dian and Zeng, Xuan},
  booktitle={2024 ACM/IEEE International Conference on Computer-Aided Design (ICCAD 24)},
  year={2024},
  organization={IEEE},
  abbr={ICCAD},
  label={AI for EDA},
  selected={false},
  abstract={Current state-of-the-art analog circuit sizing methods predominantly rely on derivative-free algorithms, but these methods struggle with sample efficiency due to the lack of derivative information, acting as a bottleneck for further advancements. Classic sensitivity analysis computes partial derivatives of circuit performance with respect to design parameters, enabling efficient first-order optimization. However, sensitivity-driven analog sizing has seen limited use due to accumulated numerical errors from nonlinear devices and the complex, non-convex nature of circuit optimization problems, which makes local search methods like gradient descent ineffective for global optimization. This paper proposes DarBO, a derivative-aware Bayesian optimization method that uses derivatives from error-suppressed adjoint sensitivity analysis to improve Gaussian process posteriors in local optimization, enhancing convergence with fewer circuit simulations. Experimental results on both synthetic benchmarks and real-world analog circuits demonstrate the effectiveness of the proposed approach.}
}

@inproceedings{li2024analoggym,
  title={AnalogGym: An open and practical testing suite for analog circuit synthesis},
  author={Li, Jintao and Zhi, Haochang and Lyu, Ruiyu and Li, Wangzhen and Bi*, Zhaori and Zhu, Keren and Zeng, Yanhan and Shan, Weiwei and Yan, Changhao and Yang, Fan and others},
  booktitle={Proceedings of the 43rd IEEE/ACM International Conference on Computer-Aided Design(ICCAD 24, Invited)},
  pages={1--9},
  year={2024},
  organization={IEEE},
  abbr={ICCAD},
  label={AI for EDA},
  selected={false},
  abstract={Recent advances in machine learning for automating analog circuit synthesis have been significant, yet challenges remain. A critical gap is the lack of a standardized evaluation framework, compounded by various process design kits, simulation tools, and a limited variety of circuit topologies. These factors hinder direct comparisons and the validation of algorithms. To address these shortcomings, we introduce AnalogGym, an open-source testing suite designed to provide fair and comprehensive evaluations. AnalogGym includes 30 circuit topologies in five categories: sensing front ends, voltage references, low dropout regulators, amplifiers, and phase-locked loops. It supports several technology nodes for academic and commercial applications and is compatible with commercial simulators such as Cadence Spectre, Synopsys HSPICE, and the open-source simulator Ngspice. AnalogGym standardizes the assessment of ML algorithms in analog circuit synthesis and promotes reproducibility with its open datasets and detailed benchmark specifications. We also conduct a comprehensive comparison of various analog sizing methods on the proposed platform.}
}

@inproceedings{ESWEEK1,
  title={ROI-HIT: Region of Interest-driven High-dimensional Microarchitecture Design Space Exploration},
  author={Zhao, Xuyang and Gao, Tianning and Zhao, Aidong and Bi*, Zhaori and Yan, Changhao and Yang, Fan and Sheng-Guo Wang and Zhou, Dian and Zeng, Xuan},
  booktitle={2024 CODES+ISSS (ESWEEK 24), best paper nomination},
  year={2024},
  organization={IEEE},
  abbr={ESWEEK},
  label={AI for EDA},
  selected={false},
  abstract={Design space exploration of RISC-V processors faces significant challenges due to the vastness of the high-dimensional design space and associated expensive simulation costs. This paper proposes ROI-HIT, a region of interest (ROI)-driven method for high-dimensional microarchitecture design space exploration, which focuses on the promising ROIs to reduce the over-exploration on the huge design space and improve the optimization efficiency. The method identifies and prioritizes regions of interest based on historical evaluation data, enabling efficient allocation of simulation resources to the most promising design configurations. Experimental results on RISC-V BOOM processor design demonstrate that ROI-HIT achieves superior Pareto-optimal designs with significantly fewer simulations compared to state-of-the-art methods.}
}


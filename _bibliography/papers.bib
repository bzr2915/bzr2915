@inproceedings{mario,
  title={MARIO: A Superadditive Multi-Algorithm Interworking Optimization Framework for Analog Circuit Sizing},
  author={Li, Wangzhen and Meng, Yuan and Lyu, Ruiyu and Yan, Changhao and Zhu, Keren and Bi, Zhaori and Zhou, Dian and Zeng, Xuan},
  booktitle={2025 62nd ACM/IEEE Design Automation Conference (DAC 25)},
  pages={1--7},
  year={2025},
  organization={IEEE},
  abbr={DAC},
  label={AI for EDA},
  selected={true},
  abstract={Numeric optimization methods are widely utilized to tackle complex analog circuit sizing problems, where the challenges include expensive simulations, non-linearity, and high parameter dimensionality. However, the diverse characteristics exhibited by different circuits result in varied optimization landscapes, making it difficult to identify a single algorithm that consistently outperforms others across all problems. This paper proposes MARIO, a multi-algorithm interworking optimization framework that achieves optimization superadditivity based on a pool of member algorithms and a powerful algorithm-interworking protocol. A computing resource reallocation method is proposed, which employs multi-task Gaussian process regression and portfolio optimization techniques, leading to flexible and prudent online adaption of member algorithms. Furthermore, a cooperative local refinement feature is introduced, allowing algorithms to share evaluation data and leverage each other's strengths for local search. Experimental results on both synthetic benchmarks and real-world analog circuits demonstrate that MARIO surpasses existing algorithm-combining tools and standard optimization methods.}
}

@inproceedings{lbyl,
  title={Look Before You Leap: A Self-Review Bayesian Optimization Method for Constrained High-Dimensional Design Space Exploration},
  author={Zhao, Xuyang and Zhao, Yiyang and Wu, Zheng and Gao, Tianning and Bi*, Zhaori and Yan, Changhao and Zhou, Dian and Zeng, Xuan},
  booktitle={2025 62nd ACM/IEEE Design Automation Conference (DAC 25)},
  pages={1--7},
  year={2025},
  organization={IEEE},
  abbr={DAC},
  label={AI for EDA},
  selected={false},
  abstract={High-dimensional constrained optimization poses significant challenges in analog circuit design automation, where expensive simulations and complex design spaces hinder efficient exploration. This paper proposes a self-review Bayesian optimization method that integrates a teacher-student paradigm within a local Bayesian optimization framework to reduce model errors and enhance exploration efficiency in constrained high-dimensional design spaces. The method employs deep ensembles for effective constraint handling, enabling reliable identification of feasible regions. Experimental results on both synthetic benchmarks and real-world analog circuits demonstrate that the proposed approach achieves superior performance compared to state-of-the-art methods for constrained high-dimensional design space exploration.}
}

@inproceedings{himoss,
  title={HiMOSS: A Novel High-Dimensional Multi-Objective Optimization Method via Adaptive Gradient-Based Subspace Sampling for Analog Circuit Sizing},
  author={Gu, Tianchen and Lyu, Ruiyu and Bi*, Zhaori and Yan, Changhao and Yang, Fan and Zhou, Dian and Cui, Tao and  Liu, Xin and Zhang, Zaikun and Zeng, Xuan},
  booktitle={2024 61th ACM/IEEE Design Automation Conference (DAC 24)},
  year={2024},
  organization={IEEE},
  abbr={DAC},
  label={AI for EDA},
  selected={false},
  abstract={This study presents a novel high-dimensional multi-objective optimization method via adaptive gradient-based subspace sampling for analog circuit sizing. To handle constrained multi-objective optimization, we exploit promising regions from a non-crowded Pareto front, with lightweight Bayesian optimization (BO) based on a novel approximate constrained expected hypervolume improvement. This lightweight BO is computational efficient with constant complexity concerning simulation numbers. To tackle high-dimensional challenges, we reduce the effective dimensionality around promising regions by sampling candidates in an adaptive subspace. The subspace is constructed with gradients and previous success steps with their significance decaying over iterations. The gradients are approximated by sparse regression without additional simulations. The experiments on synthetic benchmarks and analog circuits illustrate advantages of the proposed method over Bayesian and evolutionary baselines.}
}

@inproceedings{evdmarl,
  title={EVDMARL: Efficient Value Decomposition-based Multi-Agent Reinforcement Learning with Domain-Randomization for Complex Analog Circuit Design Migration},
  author={Sun, Handa and Bi*, Zhaori and Jiang, Wenning and Lu, Ye and Yan, Changhao and Yang, Fan and Hu, Wenchuang and Wang, Sheng-Guo and Zhou, Dian and Zeng, Xuan},
  booktitle={2024 61th ACM/IEEE Design Automation Conference (DAC 24)},
  year={2024},
  organization={IEEE},
  abbr={DAC},
  label={AI for EDA},
  selected={true},
  abstract={Automated analog circuit design migration significantly alleviates the burden on designers in circuit sizing under various operating conditions. Conventional methods model the migration problem as black-box optimization, requiring excessive iterations of costly simulations to converge. Reinforcement learning exhibits significant promise in transfer learning, as it enables the generation of circuits that fulfill specifications efficiently. This paper proposes EVDMARL, a novel value decomposition-based multi-agent reinforcement learning framework that models complex analog circuits and eliminates the need for manually defined specifications of sub-circuits for new operating conditions. Furthermore, domain randomization is incorporated to efficiently generate circuits that meet unforeseen scenarios with minimal simulations. Experimental results on real-world analog circuits demonstrate the effectiveness of the proposed framework for complex analog circuit design migration.}
}

@inproceedings{zhao2023cvts,
  title={cVTS: A Constrained Voronoi Tree Search Method for High Dimensional Analog Circuit Synthesis},
  author={Zhao, Aidong and Wang, Xianan and Lin, Zixiao and Bi*, Zhaori and Li, Xudong and Yan, Changhao and Yang, Fan and Shang, Li and Zhou, Dian and Zeng, Xuan},
  booktitle={2023 60th ACM/IEEE Design Automation Conference (DAC 23)},
  year={2023},
  organization={IEEE},
  abbr={DAC},
  label={AI for EDA},
  selected={true},
  abstract={A constrained Voronoi tree-based domain decomposition method for high-dimensional Bayesian optimization is proposed to solve large scale analog circuit synthesis problems, which can be formulated as high-dimensional heterogeneous black-box optimization. The hierarchical Voronoi tree progressively breaks down the design space into partitions with implicit performance boundaries such that promising regions are efficiently explored. Combined with a local Bayesian optimization strategy within each partition, the method effectively balances exploration and exploitation in high-dimensional spaces. Experimental results on both synthetic benchmarks and real-world analog circuits demonstrate that the proposed method significantly outperforms state-of-the-art methods in terms of optimization quality and convergence speed.}
}

@inproceedings{zhao2025seeing,
  title={BAGNet: A Boundary-Aware Graph Neural Network for SRAM Yield Analysis in Post-Layout Simulation},
  author={Sang, Haoyang and Yan, Changhao and Bi*, Zhaori and Zhu, Keren and Zeng, Xuan},
  booktitle={2025 IEEE/ACM International Conference On Computer Aided Design (ICCAD 25)},
  pages={1--9},
  year={2025},
  organization={IEEE},
  abbr={ICCAD},
  label={AI for EDA},
  selected={false},
  abstract={SRAM yield analysis in post-layout simulation is critical for ensuring reliable memory designs under process variations. This paper proposes BAGNet, a boundary-aware graph neural network that captures the complex relationships between layout parasitics and SRAM yield metrics. By incorporating boundary-aware attention mechanisms and graph-based representations of the SRAM post-layout structure, BAGNet effectively models the spatial dependencies and boundary effects that significantly impact yield. Experimental results demonstrate that BAGNet achieves highly accurate SRAM yield predictions in post-layout simulation, outperforming existing methods while providing valuable insights for yield-driven design optimization.}
}

@inproceedings{sang,
  title={Seeing Through Designs: Attention-Based Knowledge Transfer for Preference-Guided Microarchitecture Search},
  author={Zhao, Yiyang and Zhao, Xuyang and Bi*, Zhaori and Zhu, Ming and Zhan, Qiwei and Zhu, Keren and Yang, Fan and Yan, Changhao and Zhou, Dian and Zeng, Xuan},
  booktitle={2025 IEEE/ACM International Conference On Computer Aided Design (ICCAD 25)},
  pages={1--9},
  year={2025},
  organization={IEEE},
  abbr={ICCAD},
  label={AI for EDA},
  selected={false},
  abstract={Modern processor microarchitectures face increasing complexity with larger search spaces and lengthy design-to-silicon validation flows. While reusing design knowledge across architectures offers efficiency gains, the common practice remains specific-architecture search due to discrepancies in power, performance, and area metrics. This paper proposes an attention-based microarchitecture search framework for effective cross-architecture knowledge transfer. A cross-attention network is designed to capture interdependencies between microarchitectural topology and design tool configurations, enabling knowledge adaptation across architectures with minimal fine-tuning. Complemented by an uncertainty-guided optimization strategy, the framework efficiently navigates the design space based on specific user preferences. Experimental results demonstrate that the proposed method achieves significant speedup in microarchitecture design space exploration while maintaining high-quality design outcomes.}
}

@inproceedings{ajoint,
  title={Revisiting sensitivity-based analog sizing with derivative-aware Bayesian optimization and error-suppressed adjoint analysis},
  author={Lyu, Ruiyu and Zhao, Aidong and Meng, Yuan and Zhu, Keren and Bi*, Zhaori and Yan, Changhao and Yang, Fan and Zhou, Dian and Zeng, Xuan},
  booktitle={2024 ACM/IEEE International Conference on Computer-Aided Design (ICCAD 24)},
  year={2024},
  organization={IEEE},
  abbr={ICCAD},
  label={AI for EDA},
  selected={false},
  abstract={Current state-of-the-art analog circuit sizing methods predominantly rely on derivative-free algorithms, but these methods struggle with sample efficiency due to the lack of derivative information, acting as a bottleneck for further advancements. Classic sensitivity analysis computes partial derivatives of circuit performance with respect to design parameters, enabling efficient first-order optimization. However, sensitivity-driven analog sizing has seen limited use due to accumulated numerical errors from nonlinear devices and the complex, non-convex nature of circuit optimization problems, which makes local search methods like gradient descent ineffective for global optimization. This paper proposes DarBO, a derivative-aware Bayesian optimization method that uses derivatives from error-suppressed adjoint sensitivity analysis to improve Gaussian process posteriors in local optimization, enhancing convergence with fewer circuit simulations. Experimental results on both synthetic benchmarks and real-world analog circuits demonstrate the effectiveness of the proposed approach.}
}

@inproceedings{li2024analoggym,
  title={AnalogGym: An open and practical testing suite for analog circuit synthesis},
  author={Li, Jintao and Zhi, Haochang and Lyu, Ruiyu and Li, Wangzhen and Bi*, Zhaori and Zhu, Keren and Zeng, Yanhan and Shan, Weiwei and Yan, Changhao and Yang, Fan and others},
  booktitle={Proceedings of the 43rd IEEE/ACM International Conference on Computer-Aided Design(ICCAD 24, Invited)},
  pages={1--9},
  year={2024},
  organization={IEEE},
  abbr={ICCAD},
  label={AI for EDA},
  selected={false},
  abstract={Recent advances in machine learning for automating analog circuit synthesis have been significant, yet challenges remain. A critical gap is the lack of a standardized evaluation framework, compounded by various process design kits, simulation tools, and a limited variety of circuit topologies. These factors hinder direct comparisons and the validation of algorithms. To address these shortcomings, we introduce AnalogGym, an open-source testing suite designed to provide fair and comprehensive evaluations. AnalogGym includes 30 circuit topologies in five categories: sensing front ends, voltage references, low dropout regulators, amplifiers, and phase-locked loops. It supports several technology nodes for academic and commercial applications and is compatible with commercial simulators such as Cadence Spectre, Synopsys HSPICE, and the open-source simulator Ngspice. AnalogGym standardizes the assessment of ML algorithms in analog circuit synthesis and promotes reproducibility with its open datasets and detailed benchmark specifications. We also conduct a comprehensive comparison of various analog sizing methods on the proposed platform.}
}

@inproceedings{ESWEEK1,
  title={ROI-HIT: Region of Interest-driven High-dimensional Microarchitecture Design Space Exploration},
  author={Zhao, Xuyang and Gao, Tianning and Zhao, Aidong and Bi*, Zhaori and Yan, Changhao and Yang, Fan and Sheng-Guo Wang and Zhou, Dian and Zeng, Xuan},
  booktitle={2024 CODES+ISSS (ESWEEK 24), best paper nomination},
  year={2024},
  organization={IEEE},
  abbr={ESWEEK},
  label={AI for EDA},
  selected={false},
  abstract={Design space exploration of RISC-V processors faces significant challenges due to the vastness of the high-dimensional design space and associated expensive simulation costs. This paper proposes ROI-HIT, a region of interest (ROI)-driven method for high-dimensional microarchitecture design space exploration, which focuses on the promising ROIs to reduce the over-exploration on the huge design space and improve the optimization efficiency. The method identifies and prioritizes regions of interest based on historical evaluation data, enabling efficient allocation of simulation resources to the most promising design configurations. Experimental results on RISC-V BOOM processor design demonstrate that ROI-HIT achieves superior Pareto-optimal designs with significantly fewer simulations compared to state-of-the-art methods.}
}

@article{chen2025high,
  title={High-Dimensional Yield Optimization for Analog Circuits via Monte Carlo Tree Search and Self-Regressive Auto-Encoder Promoted Subspace Decomposed Gaussian Process},
  author={Chen, Zhaoting and Guo, Jianping and Bi*, Zhaori and Yan, Changhao and Yang, Fan and Zhou, Dian and Zeng, Xuan},
  journal={IEEE Transactions on Computer-Aided Design of Integrated Circuits and Systems},
  year={2025},
  publisher={IEEE},
  abbr={TCAD},
  label={AI for EDA},
  selected={false},
  abstract={Yield optimization is a critical task in analog circuit design automation, where the goal is to maximize the probability that a circuit meets its performance specifications under process variations. However, the high dimensionality of the design space poses significant challenges for efficient yield optimization. This paper proposes a high-dimensional yield optimization method for analog circuits that combines Monte Carlo tree search (MCTS) with a self-regressive auto-encoder promoted subspace decomposed Gaussian process. The MCTS quickly identifies promising local regions within the design space, while the self-regressive auto-encoder learns a compact latent representation to enable effective subspace decomposition. The subspace decomposed Gaussian process then performs efficient Bayesian optimization within the identified regions. Experimental results on real-world analog circuits demonstrate that the proposed method significantly outperforms state-of-the-art yield optimization approaches in both efficiency and solution quality.}
}

@article{shen2025atelier,
  title={Atelier: An Automated Analog Circuit Design Framework via Multiple Large Language Model-based Agents},
  author={Shen, Jinyi and Chen, Zihao and Zhuang, Ji and Huang, Jiangli and Yang*, Fan and Shang, Li and Bi*, Zhaori and Yan, Changhao and Zhou, Dian and Zeng*, Xuan},
  journal={IEEE Transactions on Computer-Aided Design of Integrated Circuits and Systems},
  year={2025},
  publisher={IEEE},
  abbr={TCAD},
  label={AI for EDA},
  selected={false},
  abstract={The design of analog circuits requires substantial domain-specific knowledge and extensive manual effort, yet data scarcity limits the application of machine learning techniques in this field. This paper presents Atelier, a large language model (LLM)-based framework for analog circuit design that integrates general-purpose LLMs with a high-quality, compact knowledge base to fulfill the considerable knowledge requirements, obviating the need for extensive domain-specific training or fine-tuning. The framework comprises several LLM agents, structured in a graph-of-thoughts architecture, with each agent specialized in a distinct task including circuit analysis, topology selection, topology modification, parameter tuning, and design decision. The collaborative multi-agent system, enriched with access to the compact knowledge base and advanced mechanisms such as self-reflection, backtracking, and tool integration, automates the analog circuit design process and significantly enhances design quality and efficiency while ensuring interpretability. Experimental results highlight Atelier's superiority over state-of-the-art black-box methods, general-purpose LLMs, and LLM-based methods, demonstrating notable improvements in success rates, design quality, and runtime.}
}

@article{zhao2024vtsmoc,
  title={VTSMOC: An Efficient Voronoi Tree Search Boosted Multi-objective Bayesian Optimization with Constraints for High-dimensional Analog Circuit Synthesis},
  author={Zhao, Aidong and Lyu, Ruiyu and Zhao, Xuyang and Bi*, Zhaori and Yang, Fan and Yan, Changhao and Zhou, Dian and Su, Yangfeng and Zeng, Xuan},
  journal={IEEE Transactions on Computer-Aided Design of Integrated Circuits and Systems},
  year={2024},
  publisher={IEEE},
  abbr={TCAD},
  label={AI for EDA},
  selected={false},
  abstract={Multi-objective optimization with constraints is an important and practical problem in high-dimensional analog circuit synthesis. This paper proposes VTSMOC, an efficient Voronoi tree search boosted multi-objective Bayesian optimization method with constraints for high-dimensional analog circuit synthesis. VTSMOC decomposes the design space into Voronoi cells, dynamically constructing a hierarchical Voronoi tree through clustering observations with dominance relationships. The hierarchical Voronoi tree progressively partitions the design space to identify promising regions with implicit performance boundaries, enabling efficient exploration of the high-dimensional multi-objective optimization landscape. Combined with a local Bayesian optimization strategy within each partition that accounts for multiple objectives and constraints, the method effectively balances exploration and exploitation. Experimental results on both synthetic benchmarks and real-world analog circuits demonstrate that VTSMOC significantly outperforms state-of-the-art multi-objective optimization methods in terms of optimization quality and convergence speed for high-dimensional constrained analog circuit synthesis.}
}

@article{APPLE,
  title={APPLE-DSE: Asynchronous Parallel Pareto Set Learning for Microarchitecture Design Space Exploration},
  author={Zhao, Xuyang and Gao, Tianning and Wu, Zheng and Bi*, Zhaori and Yan, Changhao and Yang, Fan and Wang, Sheng-Guo and Zhou, Dian and Zeng, Xuan},
  journal={IEEE Transactions on Computer-Aided Design of Integrated Circuits and Systems},
  year={2024},
  publisher={IEEE},
  abbr={TCAD},
  label={AI for EDA},
  selected={false},
  abstract={The synthesizable and parameterizable RISC-V microarchitecture, combined with multi-objective optimization-based design space exploration (DSE), facilitates agile adaptation to various microprocessor designs for customized applications. However, to enhance design quality, DSE must consider both architecture parameters and EDA tool parameters, resulting in exponentially increased optimization complexity with the dimensionality of parameters. Exhaustively exploring the whole design space is impossible, and due to the time-consuming nature of microprocessor simulation, minimizing the number of simulations is imperative. This paper proposes APPLE-DSE, an asynchronous parallel Pareto set learning method for microarchitecture DSE. APPLE-DSE utilizes the Pareto Set Learning (PSL) technique to obtain an approximate Pareto front with a light-weight evaluation. PSL captures the structural characteristics of the Pareto set guided by surrogate models, enabling exploration of any trade-off area in the approximate Pareto set. Employing the Probabilistic Reparameterization (PR) technique, APPLE-DSE adapts PSL to handle discrete variables. Furthermore, APPLE-DSE incorporates a simulation time-aware asynchronous parallel scheduling strategy to further enhance optimization efficiency. Experimental results show that APPLE-DSE achieves a maximum improvement of 16.81% in hypervolume within the same time budget and a 127.73x speedup in algorithm run time per iteration compared to state-of-the-art methods.}
}

@article{pPIRW,
  title={pPIRW: An Efficient and Accurate Pre-calculation Path Integral Random Walk Solver for Steady-State Thermal Simulation With Robin Boundary Conditions},
  author={Dong, Zhixuan and Yang, Longlong and Ding, Cuiyang and Yan, Changhao and Bi, Zhaori and Wang, Sheng-Guo and Zhou, Dian and Zeng, Xuan},
  journal={IEEE Transactions on Computer-Aided Design of Integrated Circuits and Systems},
  year={2024},
  publisher={IEEE},
  abbr={TCAD},
  label={AI for EDA},
  selected={false},
  abstract={Conventional deterministic thermal analysis methods have difficulties in obtaining local temperature solutions efficiently, and the existing stochastic method is inaccurate when dealing with thermal analysis problems involving Robin boundary conditions (BCs). This paper proposes a highly parallelized path integral random walk (PIRW) solver for steady-state thermal analysis with mixed boundary conditions, especially Robin BCs. The rigorous calculation of the local time and the Feynman-Kac functional are adopted to accurately handle Neumann and Robin boundary conditions for the first time. Based on the PIRW, an accurate and microsecond-level pre-calculation PIRW (pPIRW) predictor is proposed, which pre-calculates time-consuming random walks, obtains temperatures by simple vector multiplication, and is suitable for proactive thermal management. Compared with 3D-ICE, the PIRW solver maintains high accuracy with a negligible error within 0.5 degrees Celsius, achieves 136-209x speedup and 8.53-11.1x storage space reduction with all three kinds of boundary conditions. The pPIRW has speed improvement of 2.5e4-6.7e6x and memory reduction of 36.6-42.5x over PIRW without loss of accuracy.}
}

@article{ATOM,
  title={ATOM: An Automatic Topology Synthesis Framework for Operational Amplifiers},
  author={Shen, Jinyi and Yang, Fan and Shang, Li and Yan, Changhao and Bi, Zhaori and Zhou, Dian and Zeng, Xuan},
  journal={IEEE Transactions on Computer-Aided Design of Integrated Circuits and Systems},
  year={2024},
  publisher={IEEE},
  abbr={TCAD},
  label={AI for EDA},
  selected={false},
  abstract={Automated topology synthesis of operational amplifiers is a fundamental yet challenging task in analog circuit design automation. The design space for behavior-level opamp topologies involves numerous connections that are difficult to comprehend, and evaluating each topology incurs substantial computational costs. This paper proposes ATOM, an automatic opamp topology synthesis framework that constructs a concise design space for behavior-level opamp topologies consisting of topologies designers can easily understand, and proposes an opamp topology optimization method incorporating freeze-thaw Bayesian optimization that efficiently explores the design space and expedites the evaluation process. Experimental studies demonstrate that ATOM outperforms state-of-the-art topology synthesis methods in terms of success rate and optimization results while reducing the number of required simulations by up to 8.15 times.}
}

@article{gu2023bbgp,
  title={BBGP-sDFO: Batch Bayesian and Gaussian Process Enhanced Subspace Derivative Free Optimization for High-Dimensional Analog Circuit Synthesis},
  author={Gu, Tianchen and Li, Wangzhen and Zhao, Aidong and Bi*, Zhaori and Li, Xudong and Yang, Fan and Yan, Changhao and Hu, Wenchuang and Zhou, Dian and Cui, Tao and others},
  journal={IEEE Transactions on Computer-Aided Design of Integrated Circuits and Systems (TCAD 24)},
  year={2024},
  publisher={IEEE},
  abbr={TCAD},
  label={AI for EDA},
  selected={true},
  abstract={High-dimensional analog circuit synthesis is a challenging simulation-expensive optimization problem. This paper proposes BBGP-sDFO, a novel batch Bayesian and Gaussian process enhanced subspace derivative free optimization method to solve high-dimensional and simulation-expensive analog circuit optimization problems. The method includes a batch Bayesian querying strategy for exploring the global design space and a Gaussian process enhanced subspace derivative free optimization method for exploiting promising regions in effective low-dimensional subspace. By combining global exploration with local exploitation in reduced subspaces, BBGP-sDFO efficiently handles the curse of dimensionality while maintaining high optimization quality. Experimental results on both synthetic benchmarks and real-world analog circuits demonstrate that BBGP-sDFO significantly outperforms state-of-the-art methods in terms of optimization efficiency and solution quality for high-dimensional analog circuit synthesis.}
}

@article{chen2023pneurfill,
  title={pNeurFill: Enhanced Neural Network Model-Based Dummy Filling Synthesis With Perimeter Adjustment},
  author={Chen, Zhaoting and Cai, Junzhe and Yan, Changhao and Bi*, Zhaori and Ma, Yuzhe and Yu, Bei and Hu, Wenchuang and Zhou, Dian and Zeng, Xuan},
  journal={IEEE Transactions on Computer-Aided Design of Integrated Circuits and Systems (TCAD 24)},
  year={2024},
  publisher={IEEE},
  abbr={TCAD},
  label={AI for EDA},
  selected={false},
  abstract={Dummy filling is widely applied to significantly improve the planarity of topographic patterns for the chemical mechanical polishing (CMP) process in VLSI manufacturing, with dummy synthesis serving as the key step to adjust the post-CMP profile height. However, existing dummy synthesis optimization approaches usually fail to balance the filling quality and efficiency. This paper proposes pNeurFill, an enhanced neural network model-based dummy filling synthesis framework with perimeter adjustment, integrated with a multiple starting points-sequential quadratic programming (MSP-SQP) optimization solver. Inside this framework, a full-chip CMP simulator is first migrated to the neural network, achieving 8134x speedup on gradient calculation by backward propagation. An improved version with perimeter adjustment (pNeurFill) is further implemented to alleviate the post-CMP height variation caused by dummy perimeter. The extra perimeter adjustment strategy in pNeurFill achieves an average 66.97 Angstrom decrease in height variation and 8.92% quality improvement compared to the baseline NeurFill.}
}

@article{bao2024multiagent,
  title={Multiagent Based Reinforcement Learning (MA-RL): An Automated Designer for Complex Analog Circuits},
  author={Bao, Jiarui and Zhang, Jinxin and Huang, Zhangcheng and Feng, Xingwei and Bi, Zhaori and Zeng, Xuan and Lu, Ye},
  journal={IEEE Transactions on Computer-Aided Design of Integrated Circuits and Systems (TCAD 24)},
  year={2024},
  publisher={IEEE},
  abbr={TCAD},
  label={AI for EDA},
  selected={false},
  abstract={Despite the effort of analog circuit design automation, complex analog circuit design still requires extensive manual iterations, making it labor intensive and time-consuming. Recently, reinforcement learning (RL) algorithms have been demonstrated successfully for analog circuit design optimization. However, a robust and highly efficient RL method to design analog circuits with complex design space has not been fully explored yet. In this work, inspired by multiagent planning theory as well as human expert design practice, a multiagent-based RL (MA-RL) framework is proposed. The framework partitions complex analog circuits into several subblocks based on topology information and effectively reduces the complexity of the design search space. It leverages MA-RL for circuit optimization, where each agent corresponds to a single subblock, and the interactions between agents delicately mimic the design tradeoffs between circuit subblocks by human experts. Three different multiagent RL algorithms and corresponding frameworks are introduced and compared to demonstrate the effectiveness of the MA-RL method, with twin-delayed techniques and proximal policy employed to further boost training stability and accomplish higher performances. Experiments on three different complex analog circuit topologies (gain boost amplifier, delay-locked loop, and SAR ADC) and knowledge transfer demonstrate the advantages of the proposed approach.}
}

@article{he2022batched,
  title={A batched Bayesian optimization approach for analog circuit synthesis via multi-fidelity modeling},
  author={He, Biao and Zhang, Shuhan and Wang, Yifan and Gao, Tianning and Yang, Fan and Yan, Changhao and Zhou, Dian and Bi*, Zhaori and Zeng, Xuan},
  journal={IEEE Transactions on Computer-Aided Design of Integrated Circuits and Systems (TCAD 23)},
  year={2022},
  publisher={IEEE},
  abbr={TCAD},
  label={AI for EDA},
  selected={false},
  abstract={Analog circuit design automation and determining design parameters can be formulated as a constrained nonlinear optimization problem, with the design goal of optimizing circuit performances such as power consumption, bandwidth, and gain to meet specifications. This paper proposes a constrained batch Bayesian optimization approach for analog circuit synthesis via multi-fidelity modeling. The batch Bayesian optimization exploits parallel computing and selects promising parameters by multiple acquisition function ensemble. The multi-fidelity model combines information from low and high fidelity simulations to reduce the number of time-consuming high-fidelity simulations required. A well-designed batch selection policy improves hardware resource utilization and convergence rate. Experimental results on real-world analog circuits demonstrate that the proposed method achieves superior optimization results with significantly reduced simulation costs compared to state-of-the-art methods.}
}

@article{yang2017smart,
  title={Smart-MSP: A self-adaptive multiple starting point optimization approach for analog circuit synthesis},
  author={Yang, Yishi and Zhu, Hengliang and Bi, Zhaori and Yan, Changhao and Zhou, Dian and Su, Yangfeng and Zeng, Xuan},
  journal={IEEE Transactions on Computer-Aided Design of Integrated Circuits and Systems (TCAD 17)},
  volume={37},
  number={3},
  pages={531--544},
  year={2017},
  publisher={IEEE},
  abbr={TCAD},
  label={AI for EDA},
  abstract={Automated analog circuit design is promising for increasing the design productivity and narrowing the time-to-market, but is facing the bottleneck of tremendous design complexity. In this paper, a simulation-based optimization approach named smart-multiple starting point (MSP) is proposed for analog circuit synthesis. The proposed smart-MSP is based on the framework of MSP optimization, which is shown to be much more efficient than other global optimization methods like simulated annealing, genetic algorithm, particle swarm optimization, etc. Efficient techniques including heuristic-biased starting point selection, sparse regression and probabilistic TABU are developed in smart-MSP and make the algorithm self-adaptive by learning from the previous local searches and can efficiently produce optimal results to approximate the global optimum. Experimental results on real-world analog circuits demonstrate that smart-MSP achieves significant improvements in optimization efficiency and solution quality compared to existing approaches.}
}

@article{feng2025hierarchical,
  title={Hierarchical Integration of Reinforcement Learning and Optimization Algorithms for Time-Efficient Design Automation of Complex Analog Circuit},
  author={Feng, Xingwei and Xu, Yifan and Huang, Zhangcheng and Xu, Wuyi and Bi, Zhaori and Yang, Fan and Zeng, Xuan and Lu, Ye},
  journal={ACM Transactions on Design Automation of Electronic Systems},
  volume={30},
  number={3},
  pages={1--22},
  year={2025},
  publisher={ACM New York, NY},
  abbr={TODAES},
  label={AI for EDA},
  selected={false},
  abstract={Design automation of complex analog circuits (CAC) with multiple sub-blocks is challenging mainly due to large design search space, uncertain intermediate subgoal creation, and lengthy CAC simulation runtime. This paper proposes a hierarchical and heterogeneous integration framework as a fully automated and time-efficient CAC design optimization solution. The framework decomposes CAC into two levels hierarchically and for the first time introduces hierarchical reinforcement learning agents with hindsight and subgoal testing to automate the subgoal creation between these two levels. The subgoal converges to the optimal value through algorithm interactions. At each level, optimization algorithms are integrated to efficiently search the design space within the constraints defined by the hierarchical subgoals. Experimental results on complex analog circuits demonstrate that the proposed framework achieves significant improvements in both design quality and optimization time compared to state-of-the-art methods.}
}

@article{bi2024optimization,
  title={D3PBO: Dynamic Domain Decomposition based Parallel Bayesian Optimization for Large-scale Analog Circuit Sizing},
  author={Zhao, Aidong  and Gu, Tianchen and Bi*, Zhaori and Yang, Fan and Yan, Changhao and Zeng, Xuan and Lin, Zixiao and Hu, Wenchuang and Zhou, Dian},
  journal={ACM Transactions on Design Automation of Electronic Systems (TODAES 24)},
  volume={1},
  number={1},
  pages={1--25},
  year={2024},
  publisher={ACM New York, NY, USA},
  abbr={TODAES},
  label={AI for EDA},
  selected={false},
  abstract={Large-scale analog circuit sizing is a challenging optimization problem due to the high dimensionality and expensive simulation costs. This paper proposes D3PBO, a dynamic domain decomposition-based parallel Bayesian optimization method for large-scale analog circuit sizing. D3PBO introduces the dynamic domain decomposition method based on maximum variance between clusters, where the search space is decomposed into subdomains progressively to limit the maximal number of observations in each domain. The time complexity of D3PBO is constant for each iteration, enabling scalable optimization. Multiple Bayesian optimization instances run in parallel across the decomposed subdomains, efficiently utilizing computational resources while maintaining effective exploration of the design space. Experiments demonstrate that D3PBO obtains better results with significantly less runtime consumption compared to state-of-the-art methods, achieving up to 10x runtime speedup compared to TuRBO with better solutions for circuit optimization experiments.}
}

@article{bi2017optimization,
  title={Optimization and quality estimation of circuit design via random region covering method},
  author={Bi*, Zhaori and Zhou, Dian and Wang, Sheng-Guo and Zeng, Xuan},
  journal={ACM Transactions on Design Automation of Electronic Systems (TODAES 17)},
  volume={23},
  number={1},
  pages={1--25},
  year={2017},
  publisher={ACM New York, NY, USA},
  abbr={TODAES},
  label={AI for EDA},
  selected={false},
  abstract={Analog circuit design optimization can be formulated as a global optimization problem, where the objective is to find optimal design parameters that satisfy performance specifications. This paper proposes a random region covering method for optimization and quality estimation of circuit design. The method introduces multiple random regions to cover the design space and employs local optimization solvers initiated from random starting points within each region to explore the optimization landscape. A quality estimation framework is developed to assess the quality of obtained solutions without exhaustive enumeration, providing statistical guarantees on the optimality of the design. Experimental results on analog circuit design problems demonstrate that the proposed method achieves efficient global optimization with reliable quality estimation, outperforming conventional optimization approaches.}
}
@article{GAOTIANNING,
  title={A RISC-V PPA-fusion Cooperative Optimization Framework Based on Hybrid Strategies},
  author={Gao,Tianning and Wang, Yifan and Zhu, Ming, and Wu, Xiulong and Zhou, Dian and Bi*, Zhaori},
  journal={IEEE Transactions on Very Large Scale Integration (VLSI) Systems (TVLSI 24)},
  volume={--},
  number={--},
  pages={--},
  year={2024},
  publisher={IEEE},
  abbr={TVLSI},
  label={AI for EDA},
  abstract={The optimization of RISC-V designs, encompassing both microarchitecture and CAD tool parameters, is a great challenge due to an extensive and high-dimensional search space. To achieve optimal results across various RISC-V designs, this paper proposes a cooperative optimization framework (COF) that integrates multiple black-box optimizers, each specializing in different optimization problems, based on hybrid strategies. The COF introduces the landscape knowledge exchange mechanism (LKEM) to direct the optimizers to share their knowledge of the optimization problem, and employs the dynamic computational resource allocation (DCRA) strategies to dynamically allocate computational resources to the optimizers. By fusing PPA (power, performance, and area) objectives, the framework enables comprehensive cooperative optimization of RISC-V processor designs. Experimental results demonstrate that the proposed framework achieves superior PPA trade-offs compared to state-of-the-art design space exploration methods.}
}
@article{qian2014automated,
  title={Automated technology migration methodology for mixed-signal circuit based on multistart optimization framework},
  author={Qian, Liuxi and Bi, Zhaori and Zhou, Dian and Zeng, Xuan},
  journal={IEEE Transactions on Very Large Scale Integration (VLSI) Systems (TVLSI 14)},
  volume={23},
  number={11},
  pages={2595--2605},
  year={2014},
  publisher={IEEE},
  abbr={TVLSI},
  label={AI for EDA},
  abstract={Technology migration for mixed-signal circuits from one process node to another is a critical but labor-intensive task in the semiconductor industry. This paper presents a hierarchical methodology for efficiently migrating mixed-signal circuit design from one technology node to another, while keeping the same circuit and layout topologies. The multistart global optimization technique is applied to resize the transistor-level block in systematic connection, which provides a good initial point for next system-level refinement. For obtaining a process and parasitic closure solution, both parasitic and process variation effects are explored and used to constrain the schematic migration. A representative mixed-signal system, charge-pump phase-locked loop, is used to validate the proposed methodology. The experimental results show that the proposed methodology efficiently generates quality designs in target technology with much less simulation iterations, when comparing with recent available approaches.}
}
@inproceedings{tSS-BO,
  title={tSS-BO: Scalable Bayesian Optimization for Analog Circuit Sizing via Truncated Subspace Sampling},
  author={Gu, Tianchen and Wang, Jiaqi and Bi*, Zhaori and Yan, Changhao and Yang, Fan and Qin, Yajie and Cui, Tao and Zeng, Xuan},
  booktitle={2024 Design, Automation and Test in Europe Conference (DATE 24)},
  pages={1},
  year={2024},
  organization={IEEE},
  abbr={DATE},
  label={AI for EDA},
  abstract={Bayesian optimization (BO) has emerged as a powerful tool for analog circuit sizing, yet its scalability to high-dimensional design spaces remains a critical challenge. This paper proposes tSS-BO, a novel scalable Bayesian optimization method with truncated subspace sampling for large-scale analog circuit sizing. The method addresses the curse of dimensionality by performing optimization in truncated subspaces that capture the most important design variable interactions, thereby reducing the effective dimensionality of the problem while preserving optimization quality. The truncated subspace is adaptively constructed based on observed data to focus the search on the most influential dimensions. Experimental results on both synthetic benchmarks and real-world analog circuits demonstrate that tSS-BO significantly outperforms existing high-dimensional Bayesian optimization methods in terms of optimization efficiency and solution quality.}
}
@inproceedings{CRC,
  title={Circuits Physics Constrained Predictor of Static IR Drop with Limited Data},
  author={Meng, Yuan and Lyu, Ruiyu and Bi*, Zhaori and Yan, Changhao and Yang, Fan and Hu, Wenchuang and Zhou, Dian and Zeng, Xuan},
  booktitle={2024 Design, Automation and Test in Europe Conference (DATE 24)},
  pages={1},
  year={2024},
  organization={IEEE},
  abbr={DATE},
  label={AI for EDA},
  abstract={Accurate prediction of static IR drop in power delivery networks (PDN) is crucial for ensuring reliable chip operation. However, existing learning-based methods require large amounts of training data, which is expensive to obtain through detailed simulation. This paper proposes a circuits physics constrained predictor that achieves highly accurate IR drop prediction with limited data. A pyramid scene parsing network with skip-connection architecture is employed to effectively utilize physical information that characterizes IR drop distribution, including current source locations, via locations, and asymmetric topological connections. The skip-connection architecture preserves the positional information of current sources, which often correlates with large IR drop, facilitating the identification of hotspots. Via locations are incorporated to effectively describe the topological connection distance between voltage sources and different nodes in the multi-layer PDN. Experimental results demonstrate that the proposed method achieves high prediction accuracy for PDN of varying scales even with a limited dataset.}
}

@inproceedings{zhao2024multiobj,
  title={Synchronous Batch Constrained Multi-Objective Bayesian Optimization for Analog Circuit Sizing},
  author={Zhao, Xuyang and Bi*, Zhaori and Yan, Changhao and Yang, Fan and Lu, Ye and Zhou, Dian and Zeng, Xuan},
  booktitle={2024 29th Asia and South Pacific Design Automation Conference (ASP-DAC 24)},
  pages={1},
  year={2024},
  organization={IEEE},
  abbr={ASP-DAC},
  label={AI for EDA},
  abstract={For analog circuit sizing, constrained multi-objective optimization is an important and practical problem. With the popularity of multi-core machines and cloud computing, parallel batch computing can significantly improve the efficiency of optimization algorithms. This paper proposes an asynchronous batch constrained multi-objective Bayesian optimization algorithm (ABCMOBO) for analog circuit sizing. The algorithm adopts a dynamic reference point selection on the expected hypervolume improvement acquisition function for constraint handling. To save the time of waiting for all simulations in the same batch to complete, ABCMOBO asynchronously evaluates the next candidate point if there is an idle worker. Experimental results quantitatively demonstrate that the proposed algorithm can reach 3.49 to 8.18x speed-up with comparable optimization results compared to the state-of-the-art asynchronous and synchronous batch multi-objective optimization methods.}
}
@inproceedings{lv2024multiobj,
  title={A Study on Exploring and Exploiting the High-dimensional Design Space for Analog Circuit Design Automation},
  author={Lyu, Ruiyu and Meng, Yuan and Zhao, Aidong and Bi*, Zhaori and Zhu, Keren and Yang, Fan and Yan, Changhao and Zhou, Dian and Zeng, Xuan},
  booktitle={2024 29th Asia and South Pacific Design Automation Conference (ASP-DAC 24)},
  pages={1},
  year={2024},
  organization={IEEE},
  abbr={ASP-DAC},
  label={AI for EDA},
  abstract={The escalated intricacy of analog circuits, compounded by the high-dimensional nature of the design space, introduces significant complexities in optimizing circuit performance. Since circuit evaluation through simulation is resource-intensive and time-consuming, the goal is to obtain a feasible design with a decent Figure of Merit (FOM) value within a limited simulation budget. This paper conducts an in-depth review and analysis of cutting-edge exploration and exploitation techniques developed to address the intricacies encountered in analog circuit design automation. We systematically examine methods for navigating the high-dimensional design space, including subspace decomposition, dimensionality reduction, and local search strategies, and discuss their effectiveness in balancing exploration of unknown regions with exploitation of promising areas for efficient analog circuit sizing.}
}
@inproceedings{zhao2022novel,
  title={A Novel and Efficient Bayesian Optimization Approach for Analog Designs with Multi-Testbench},
  author={Zhao, Jingyao and Yan, Changhao and Bi, Zhaori and Yang, Fan and Zeng, Xuan and Zhou, Dian},
  booktitle={2022 27th Asia and South Pacific Design Automation Conference (ASP-DAC 22)},
  pages={86--91},
  year={2022},
  organization={IEEE},
  abbr={ASP-DAC},
  label={AI for EDA},
  abstract={Analog circuits are characterized by various circuit performances obtained from multiple testbenches which need to be simulated independently. This paper proposes a novel and efficient Bayesian optimization approach for analog designs with multi-testbench. Predictive Entropy Search with Constraints (PESC) is applied for selecting the suitable testbench to simulate, and time-weighted PESC (wPESC) is also proposed considering different analysis time. Furthermore, the Feasibility Expected Improvement (FEI) acquisition function for constraints and solving a multi-modal optimal problem of FEI are proposed to improve the efficiency of exploring feasible regions. Experimental results on real-world analog circuits demonstrate that the proposed approach can gain 2.7 to 3.8x speedup compared with the state-of-the-art method, and achieve better optimization results.}
}
@inproceedings{fu2022batch,
  title={A Batch Bayesian Optimization Approach For Analog Circuit Synthesis Based On Multi-Points Selection Criterion},
  author={Fu, Xu and Yan, Changhao and Bi, Zhaori and Yang, Fan and Zhou, Dian and Zeng, Xuan},
  booktitle={2022 IEEE International Symposium on Circuits and Systems (ISCAS 22)},
  pages={2886--2890},
  year={2022},
  organization={IEEE},
  abbr={ISCAS},
  label={AI for EDA},
  abstract={This paper proposes an efficient batch Bayesian optimization algorithm for analog circuit synthesis based on the multi-points selection criterion. Simplex evolution operator and Niching Migratory Multi-Swarm Optimizer (NMMSO) are used to generate candidates. The multi-point selection criterion is adopted to select multiple points from the candidates for parallel evaluation, which can make full use of the computing resources. The experimental results demonstrate that this method can reduce the simulation time effectively while achieving better optimization results. Compared with the Multi-objective Acquisition function Ensemble (MACE) and the weighted expected improvement based Bayesian optimization (WEIBO), the proposed approach can accelerate the optimization process by up to 3x and 27x respectively.}
}
@inproceedings{iseda1,
  title={HD-MCTS: An Analog Circuit Optimization Algorithm Based on High-dimensional Monte Carlo Tree Search},
  author={Yiyang, Zhao and Li, Lemeng and Lyv, Ruiyu and Bi*, Zhaori and Yan, Changhao and  Zeng, Xuan},
  booktitle={2022 IEEE International Symposium of EDA (ISEDA 24), best paper},
  year={2024},
  organization={IEEE},
  abbr={ISEDA},
  label={AI for EDA},
  abstract={With the development of semiconductor technology, the design of analog circuits still relies heavily on manual effort, creating an urgent need for automated design tools. This paper proposes HD-MCTS, an analog circuit optimization algorithm based on high-dimensional Monte Carlo tree search. The method combines the advantages of Bayesian optimization and dynamic Monte Carlo tree search to obtain the feasible solution space through adaptive clustering, thereby narrowing the search range of the Bayesian optimization algorithm and improving optimization efficiency. For the Ackley test function, low-noise transconductance amplifier and bandgap voltage reference experiments, compared with Trust Region Bayesian Optimization (TuRBO), the optimization outcomes are enhanced by 20.4 percent to 46.5 percent, leading to a speedup of 0.95 to 2.62 times.}
}
@inproceedings{iseda2,
  title={High-Dimensional Analog Circuit Sizing via Bayesian Optimization in the Variational Autoencoder Enhanced Latent Space },
  author={Li, Wangzhen and Bi*, Zhaori and Zeng, Xuan},
  booktitle={2022 IEEE International Symposium of EDA (ISEDA 24)},
  year={2024},
  organization={IEEE},
  abbr={ISEDA},
  label={AI for EDA},
  abstract={High-dimensional analog circuit sizing is a challenging optimization problem due to the curse of dimensionality and expensive circuit simulations. This paper proposes a method for high-dimensional analog circuit sizing via Bayesian optimization in a variational autoencoder (VAE) enhanced latent space. The VAE is trained on circuit design data to learn a compact, continuous latent representation that captures meaningful relationships between design parameters. Bayesian optimization is then performed in this lower-dimensional latent space, enabling more efficient exploration of the design space. The approach effectively reduces the dimensionality of the optimization problem while preserving the essential structure of the design space, leading to improved optimization efficiency and solution quality for large-scale analog circuit sizing.}
}
@inproceedings{iseda3,
  title={Automated Design of Analog Circuits Based on Parallel Trust Region Bayesian Optimization},
  author={Dong, Peng and Lyu, Ruiyu and Wang, Chunxi and Chen, Jiale and Jiang, Linfeng and Lan, Cunqing and Bi*, Zhaori and Yan, Changhao},
  booktitle={2022 IEEE International Symposium of EDA (ISEDA 24)},
  year={2024},
  organization={IEEE},
  abbr={ISEDA},
  label={AI for EDA},
  abstract={Automated analog circuit design requires efficient optimization methods that can handle the complex, multi-dimensional parameter spaces of modern circuits. This paper proposes an automated design approach for analog circuits based on parallel trust region Bayesian optimization. The algorithm operates in parallel on different trust regions, utilizing a Multi-Armed Bandit algorithm for intelligent sampling to accelerate parameter optimization. By maintaining multiple trust regions simultaneously, the method effectively balances local exploitation within promising regions and global exploration of the design space. Circuit experimental results demonstrate the advantages of this algorithm in achieving faster convergence and better optimization outcomes compared to existing approaches.}
}
@inproceedings{iseda4,
  title={Topology Optimization of Operational Amplifiers Using A Performance-aware Representation},
  author={Shen, Jinyi and Yang, Fan and Shang, Li and Yan, Changhao and Bi, Zhaori and Zhou, Dian and Zeng, Xuan},
  booktitle={2022 IEEE International Symposium of EDA (ISEDA 24)},
  year={2024},
  organization={IEEE},
  abbr={ISEDA},
  label={AI for EDA},
  abstract={Automated topology synthesis of operational amplifiers is a fundamental challenge in analog circuit design automation. This paper proposes a performance-aware representation for topology optimization of operational amplifiers that encodes circuit topologies in a way that captures their performance characteristics. The representation enables efficient search over the discrete topology space by embedding performance-relevant structural information, allowing optimization algorithms to effectively navigate the vast space of possible amplifier configurations. Experimental results demonstrate that the proposed performance-aware representation leads to more efficient topology optimization and the discovery of high-quality operational amplifier designs.}
}
@inproceedings{iseda5,
  title={On  Accelerating  Domain-Specific  MC-TS  with  Knowledge  Retention  and  Efficient  Parallelization  for  Logic Optimization},
  author={Lan, Cunqing and Wang, Xinyao and Jiang, Zijian and Pan, Hongyang and Zhu, Keren and Bi, Zhaori and Yan, Changhao and Zeng, Xuan},
  booktitle={2022 IEEE International Symposium of EDA (ISEDA 24)},
  year={2024},
  organization={IEEE},
  abbr={ISEDA},
  label={AI for EDA},
  abstract={Logic synthesis optimization is a critical step in the electronic design automation flow, where the quality of the synthesis recipe significantly impacts the Quality-of-Result (QoR). This paper proposes a method for accelerating domain-specific Monte Carlo tree search (MC-TS) with knowledge retention and efficient parallelization for logic optimization. The approach incorporates a knowledge retention mechanism that preserves and reuses valuable search experiences across different optimization runs, avoiding redundant exploration. Furthermore, an efficient parallelization strategy is designed to enable concurrent evaluation of multiple synthesis recipes, significantly reducing the total optimization time. Experimental results demonstrate that the proposed method achieves superior QoR compared to existing approaches while substantially reducing the computational overhead.}
}
@inproceedings{li2015analog,
  title={Analog circuit performance bound estimation based on extreme value theory},
  author={Li, Minghua and Bi, Zhaori and Zhou, Dian and Zeng, Xuan},
  booktitle={2015 IEEE 58th International Midwest Symposium on Circuits and Systems (MWSCAS 15)},
  pages={1--4},
  year={2015},
  organization={IEEE},
  abbr={MWSCAS},
  label={AI for EDA},
  abstract={Performance bound estimation is an important task in analog circuit design, as it provides designers with critical information about the achievable performance limits under process variations. This paper proposes a novel performance bound estimation method for analog circuits based on extreme value theory. The method generates a generalized extreme value (GEV) distribution of performance parameters through sampling, enabling accurate estimation of the worst-case and best-case performance bounds without exhaustive Monte Carlo simulations. The approach provides a statistically rigorous framework for bounding circuit performance and offers significant computational savings compared to traditional methods.}
}

@inproceedings{bi2013mixed,
  title={Mixed-signal system verification by SystemC/SystemC-AMS and HSIM-VCS in near field communication tag design},
  author={Bi, Zhaori and Li, Wei and Zhou, Dian and Zeng, Xuan and Wang, Sheng-Guo},
  booktitle={2013 IEEE 10th International Conference on ASIC (ASCION 13)},
  pages={1--4},
  year={2013},
  organization={IEEE},
  abbr={ASCION},
  label={AI for EDA},
  abstract={This paper presents a verification methodology for mixed-signal systems by combining SystemC/SystemC-AMS and HSIM-VCS verification platforms. The methodology is applied to design a Near Field Communication (NFC) tag and verify its function under certain noise conditions. SystemC-AMS is used for high-level behavioral modeling of the analog and mixed-signal components, while HSIM-VCS provides transistor-level simulation accuracy for critical circuit blocks. The combined approach enables efficient system-level verification of the NFC tag design, balancing simulation speed and accuracy across different levels of abstraction.}
}

